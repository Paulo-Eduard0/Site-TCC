<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TerceiraTela">


    <ImageView
        android:layout_width="match_parent"
        android:layout_height="174dp"
        android:src="@drawable/brain"
        android:layout_gravity="center_horizontal"
        />


    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:fontFamily="sans-serif"
        android:padding="25dp"
        android:text="CADASTRO"
        android:textColor="#0B2E4B"
        android:textSize="32sp"
        android:textStyle="bold"
        tools:layout_editor_absoluteX="97dp"
        tools:layout_editor_absoluteY="188dp" />

    <EditText

        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#FFFF"
        android:hint="Digite seu Nome de usuário"
        android:inputType="textEmailAddress"
        android:padding="12dp"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="309dp" />

    <EditText
        android:id="@+id/caixaTextoEmail"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#FFFF"
        android:hint="Digite seu e-mail"
        android:inputType="textEmailAddress"
        android:padding="12dp"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="386dp" />

    <EditText
        android:id="@+id/caixaTextoSenha"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#FFFF"
        android:hint="Digite a senha"
        android:inputType="textPassword"
        android:padding="12dp"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="463dp" />

    <Button
        android:id="@+id/botao"
        android:layout_width="127dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:backgroundTint="#6495ED"
        android:padding="20dp"
        android:text="Enviar"
        android:textSize="18sp"
        tools:layout_editor_absoluteX="142dp"
        tools:layout_editor_absoluteY="535dp" />


</androidx.constraintlayout.widget.ConstraintLayout>